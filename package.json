{
  "name": "hp_ext",
  "displayName": "HP Browser Extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "hp's browser extension",
  "repository": {
    "type": "git",
    "url": "https://github.com/hariprasadr1hp/hp_ext"
  },
  "engines": {
    "node": ">=23",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:chrome": "cross-env TARGET_BROWSER=chrome vite build",
    "build:firefox": "cross-env TARGET_BROWSER=firefox vite build",
    "build:all": "pnpm run build:chrome && pnpm run build:firefox",
    "clean": "rm -rf dist/",
    "clean-install": "rm -rf node_modules/ package-lock.json && pnpm i",
    "lint": "eslint . --ext .ts --fix",
    "lint:manifest": "web-ext lint --pretty",
    "preview": "vite preview --port 5050",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@casl/ability": "^6.8.0",
    "@mdi/font": "^7.4.47",
    "@pola-rs/browser": "0.0.1-alpha",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@vitejs/plugin-react": "^5.2.0",
    "ag-grid-community": "^35.2.0",
    "ag-grid-vue3": "^35.2.0",
    "axios": "^1.14.0",
    "jwt-decode": "^4.0.0",
    "lightweight-charts": "^5.1.0",
    "marked": "^17.0.5",
    "nodejs-polars": "^0.23.5",
    "pinia": "^3.0.4",
    "plotly.js-dist-min": "^3.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-chrome-extension": "^3.6.15",
    "sass": "^1.98.0",
    "svelte": "^5.55.0",
    "vue": "^3.5.31",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@types/webfontloader": "^1.6.38",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-sfc": "^3.5.31",
    "axios-mock-adapter": "^2.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vue-tsc": "^3.2.6",
    "web-ext": "^9.4.0",
    "webext-bridge": "^6.0.1"
  },
  "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a"
}
